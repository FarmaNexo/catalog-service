{
  "environment_variables": [
    { "name": "ENV", "value": "${environment}" },
    { "name": "AWS_REGION", "value": "${aws_region}" },
    { "name": "SQS_CATALOG_EVENTS_URL", "value": "${sqs_catalog_events_queue_url}" },
    { "name": "S3_PRODUCTS_BUCKET", "value": "${s3_assets_bucket}" },
    { "name": "PHARMACY_SERVICE_URL", "value": "${pharmacy_service_url}" }
  ],
  "secrets": [
    { "name": "DB_HOST", "valueFrom": "${aurora_cluster_endpoint_secret_arn}" },
    { "name": "DB_USER", "valueFrom": "${db_catalog_db_user_secret_arn}" },
    { "name": "DB_PASSWORD", "valueFrom": "${db_catalog_db_password_secret_arn}" },
    { "name": "JWT_SECRET", "valueFrom": "${jwt_secret_arn}" },
    { "name": "REDIS_HOST", "valueFrom": "${redis_endpoint_secret_arn}" },
    { "name": "REDIS_PASSWORD", "valueFrom": "${redis_auth_token_secret_arn}" }
  ]
}
